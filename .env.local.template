# Google OAuth Credentials
# Format these in the Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Configuration
# For production, NEXTAUTH_URL should be the base URL (e.g. https://yourdomain.com)
# For local development, NextAuth handles it automatically if not set.
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_generated_nextauth_secret_here
# AUTH_SECRET is the one used by Auth.js v5 (beta)
AUTH_SECRET=your_generated_auth_secret_here
